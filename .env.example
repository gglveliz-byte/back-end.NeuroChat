# ===========================================
# ChatBot SaaS Backend - Variables de Entorno
# ===========================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa todos los valores requeridos
# 3. NUNCA subas .env a Git
# ===========================================

# ─── SERVIDOR ───
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ─── BASE DE DATOS (PostgreSQL) ───
# Render: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://usuario:password@localhost:5432/chatbot_saas

# ─── REDIS ───
REDIS_URL=redis://localhost:6379

# ─── JWT / SEGURIDAD ───
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=genera_un_secreto_muy_largo_aqui
JWT_EXPIRES_IN=8h
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=genera_un_hex_de_64_caracteres_aqui

# ─── ADMIN (sin tabla en BD) ───
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=tu_password_seguro_aqui
ADMIN_NAME=Administrador
# ADMIN_PASSWORD_HASH=  # Se genera automáticamente al iniciar si no está definido

# ─── OPENAI ───
OPENAI_API_KEY=sk-...

# ─── GROQ (plan trial - gratis en console.groq.com) ───
GROQ_API_KEY=gsk_...

# ─── META (WhatsApp / Messenger / Instagram) ───
META_APP_ID=tu_facebook_app_id
META_APP_SECRET=tu_meta_app_secret
META_VERIFY_TOKEN=tu_verify_token_personalizado
META_CONFIG_ID=tu_embedded_signup_config_id
META_INSTAGRAM_APP_SECRET=

# ─── TELEGRAM ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=tu_telegram_webhook_secret

# ─── PAYPAL ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox
# Ejemplo producción: PAYPAL_RETURN_BASE_URL=https://neurochat.com.ec
PAYPAL_RETURN_BASE_URL=http://localhost:3000

# ─── CLOUDINARY (almacenamiento imágenes) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── EMAIL (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail

# ─── DATOS BANCARIOS (pagos manuales) ───
BANK_NAME=Nombre del Banco
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_HOLDER=Tu Nombre Completo

# ─── BIRD (proveedor alternativo mensajería Meta) ───
BIRD_API_KEY=
BIRD_WORKSPACE_ID=

# ─── ELEVENLABS (texto a voz) ───
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── WHISPERX (transcripción de audio) ───
WHISPERX_URL=http://localhost:8765
WHISPERX_API_KEY=whisperx-secret-key-change-me

# ─── VOXIMPLANT (llamadas telefónicas) ───
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_API_ENDPOINT=
VOXIMPLANT_APP_NAME=
VOXIMPLANT_WEBHOOK_SECRET=

# ─── WEBHOOKS ───
WEBHOOK_API_KEY=tu_webhook_key_segura
WEBHOOK_VERIFY_TOKEN=

# ─── DESARROLLO ───
# NUNCA poner true en producción
SKIP_WEBHOOK_VERIFICATION=false
